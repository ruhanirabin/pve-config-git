#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VERSION_FILE="$REPO_ROOT/VERSION"
LIB_FILE="${LIB_FILE:-$SCRIPT_DIR/pcg-agent-lib.sh}"
[ -f "$LIB_FILE" ] || LIB_FILE="/usr/local/bin/pcg-agent-lib.sh"
# shellcheck disable=SC1090
source "$LIB_FILE"

PCG_BIN_TARGET="/usr/local/bin"
PCG_SYSTEMD_TARGET="/etc/systemd/system"
PCG_ENV_TARGET="/root/.pcg-agent.env"
PCG_ENV_DRAFT="/root/.pcg-agent-install-draft.env"
PCG_ENV_LEGACY="/root/.backup-config.env"
PCG_ENV_EXAMPLE_SOURCE="$REPO_ROOT/env/pcg-agent.env.example"
PCG_RUNTIME_VERSION_FILE="$PCG_BIN_TARGET/pcg-agent-version"
PCG_RUNTIME_VERSION_LEGACY="$PCG_BIN_TARGET/proxmox-agent-version"
PCG_BACKUP_DIR_BASE="/root/pcg-backups"
PCG_UPGRADE_LOG="/var/log/pcg-upgrade.log"
PCG_SSH_PRIVATE_KEY="/root/.ssh/id_ed25519"
PCG_SSH_PUBLIC_KEY="/root/.ssh/id_ed25519.pub"
pcg_ui_init
C_RESET="${PCG_UI_C_RESET}"
C_BOLD="${PCG_UI_C_BOLD}"
ICON_Q="${PCG_UI_ICON_Q}"

ui_info() { pcg_ui_info "$*"; }
ui_ok() { pcg_ui_ok "$*"; }
ui_warn() { pcg_ui_warn "$*"; }
ui_err() { pcg_ui_err "$*"; }

print_cli_divider() {
  local width=55
  local ch="-"
  if [ "${PCG_UI_ICON_STEP:-[>]}" = "➤" ]; then
    ch="━"
  fi
  echo "${PCG_UI_C_BLUE}$(printf "%${width}s" "" | tr ' ' "$ch")${PCG_UI_C_RESET}"
}

print_install_identity_block() {
  print_cli_divider
  echo "${PCG_UI_C_BOLD}Proxmox Cluster Guardian Installer${PCG_UI_C_RESET}"
  echo "${PCG_UI_C_CYAN}Version:${PCG_UI_C_RESET} v$(get_repo_version)"
  echo "${PCG_UI_C_CYAN}By:${PCG_UI_C_RESET} Ruhani Rabin"
  echo "${PCG_UI_C_CYAN}Website:${PCG_UI_C_RESET} https://github.com/ruhanirabin/proxmox-agent"
  print_cli_divider
}

is_test_mode() {
  pcg_bool_true "${PCG_TEST_MODE:-false}"
}

pcg_systemctl() {
  if is_test_mode; then
    ui_warn "[test mode] skipped: systemctl $*"
    return 0
  fi
  systemctl "$@"
}

PCG_CANONICAL_BIN_FILES=(
  "pcg-doctor.sh"
  "pcg-backup-config.sh"
  "pcg-boot-notify.sh"
  "pcg-send-telegram.sh"
  "pcg-send-webhook.sh"
  "pcg-shutdown-proxmox.sh"
  "pcg-agent-lib.sh"
  "pcg"
  "pcg-agent-version"
)

PCG_CANONICAL_UNIT_FILES=(
  "pa-backup-config.service"
  "pa-backup-config.timer"
  "pa-boot-notify.service"
  "pa-shutdown-proxmox.service"
)

PCG_LEGACY_BIN_FILES=(
  "proxmox-agent"
  "pa-agent-lib.sh"
  "pa-backup-config.sh"
  "pa-boot-notify.sh"
  "pa-doctor.sh"
  "pa-send-telegram.sh"
  "pa-send-webhook.sh"
  "pa-shutdown-proxmox.sh"
  "pa-agent-version"
  "backup-config.sh"
  "proxmox-boot-notify.sh"
  "send_telegram.sh"
  "send_webhook.sh"
  "shutdown-proxmox.sh"
  "proxmox-agent-lib.sh"
  "proxmox-agent-version"
)

PCG_LEGACY_UNIT_FILES=(
  "backup-config.service"
  "backup-config.timer"
  "proxmox-bootup-telegram.service"
  "shutdown-proxmox.service"
)

get_repo_version() {
  if [ -f "$VERSION_FILE" ]; then
    tr -d '[:space:]' < "$VERSION_FILE"
  else
    echo "unknown"
  fi
}

prompt_yes_no() {
  local prompt="${1:-Continue?}"
  local default="${2:-y}"
  local answer
  while true; do
    if [ "$default" = "y" ]; then
      read -r -p "${ICON_Q} $prompt [Y/n]: " answer
      answer="${answer:-y}"
    else
      read -r -p "${ICON_Q} $prompt [y/N]: " answer
      answer="${answer:-n}"
    fi
    case "$(echo "$answer" | tr '[:upper:]' '[:lower:]')" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
    esac
  done
}

set_env_kv() {
  local file="$1"
  local key="$2"
  local value="$3"
  local escaped
  local tmp_file
  escaped="$(printf '%q' "$value")"
  touch "$file"
  tmp_file="$(mktemp)"
  awk -v k="$key" -v v="$escaped" '
    BEGIN { replaced = 0 }
    $0 ~ ("^" k "=") {
      print k "=" v
      replaced = 1
      next
    }
    { print }
    END {
      if (replaced == 0) {
        print k "=" v
      }
    }
  ' "$file" > "$tmp_file"
  cat "$tmp_file" > "$file"
  rm -f "$tmp_file"
}

prompt_value() {
  local prompt="$1"
  local default="${2:-}"
  local answer
  if [ -n "$default" ]; then
    read -r -p "${ICON_Q} $prompt [$default]: " answer
    echo "${answer:-$default}"
  else
    read -r -p "${ICON_Q} $prompt: " answer
    echo "$answer"
  fi
}

prompt_choice() {
  local prompt="$1"
  local default="$2"
  shift 2
  local options=("$@")
  local answer normalized
  while true; do
    echo "${ICON_Q} $prompt (${options[*]}) [${default}]" >&2
    read -r -p "> " answer
    normalized="$(echo "${answer:-$default}" | tr '[:upper:]' '[:lower:]')"
    for opt in "${options[@]}"; do
      if [ "$normalized" = "$opt" ]; then
        echo "$normalized"
        return 0
      fi
    done
    ui_warn "Invalid choice: ${answer:-$default}"
  done
}

prompt_notification_mode() {
  local current="${1:-telegram}"
  local default_num="1"
  local answer normalized

  case "$current" in
    telegram) default_num="1" ;;
    webhook) default_num="2" ;;
    both) default_num="3" ;;
    later) default_num="4" ;;
    *) default_num="1" ;;
  esac

  while true; do
    echo "${ICON_Q} Notification mode:" >&2
    echo "  1. Telegram" >&2
    echo "  2. Webhook" >&2
    echo "  3. Both" >&2
    echo "  4. Do it later (use placeholders)" >&2
    read -r -p "${ICON_Q} Choose [1-4] [${default_num}]: " answer
    normalized="$(echo "${answer:-$default_num}" | tr '[:upper:]' '[:lower:]')"
    case "$normalized" in
      1|telegram) echo "telegram"; return 0 ;;
      2|webhook) echo "webhook"; return 0 ;;
      3|both) echo "both"; return 0 ;;
      4|later|placeholder|placeholders) echo "later"; return 0 ;;
      *) ui_warn "Invalid choice: ${answer:-$default_num}" ;;
    esac
  done
}

prompt_final_action() {
  local current="${1:-install}"
  local default_num="1"
  local answer normalized

  case "$current" in
    install) default_num="1" ;;
    save) default_num="2" ;;
    exit) default_num="3" ;;
    *) default_num="1" ;;
  esac

  while true; do
    echo "${ICON_Q} Final action:" >&2
    echo "  1. Install (apply settings and continue)" >&2
    echo "  2. Save (save settings and continue later)" >&2
    echo "  3. Exit (cancel without applying settings)" >&2
    read -r -p "${ICON_Q} Choose [1-3] [${default_num}]: " answer
    normalized="$(echo "${answer:-$default_num}" | tr '[:upper:]' '[:lower:]')"
    case "$normalized" in
      1|install) echo "install"; return 0 ;;
      2|save) echo "save"; return 0 ;;
      3|exit) echo "exit"; return 0 ;;
      *) ui_warn "Invalid choice: ${answer:-$default_num}" ;;
    esac
  done
}

prompt_existing_install_action() {
  local answer normalized
  while true; do
    echo "${ICON_Q} Existing installation detected. Choose action:" >&2
    echo "  1. Reinstall" >&2
    echo "  2. Uninstall" >&2
    echo "  3. Exit without making changes" >&2
    read -r -p "${ICON_Q} Choose [1-3] [1]: " answer
    normalized="$(echo "${answer:-1}" | tr '[:upper:]' '[:lower:]')"
    case "$normalized" in
      1|reinstall) echo "reinstall"; return 0 ;;
      2|uninstall) echo "uninstall"; return 0 ;;
      3|exit) echo "exit"; return 0 ;;
      *) ui_warn "Invalid choice: ${answer:-1}" ;;
    esac
  done
}

detect_pkg_manager() {
  if command -v apt-get >/dev/null 2>&1; then
    echo "apt"
  elif command -v dnf >/dev/null 2>&1; then
    echo "dnf"
  elif command -v yum >/dev/null 2>&1; then
    echo "yum"
  elif command -v zypper >/dev/null 2>&1; then
    echo "zypper"
  elif command -v pacman >/dev/null 2>&1; then
    echo "pacman"
  elif command -v apk >/dev/null 2>&1; then
    echo "apk"
  else
    echo ""
  fi
}

map_cmds_to_packages() {
  local pkg_manager="$1"
  shift
  local missing_cmds=("$@")
  local -A seen=()
  local cmd pkg
  local packages=()
  for cmd in "${missing_cmds[@]}"; do
    pkg="$cmd"
    case "$pkg_manager:$cmd" in
      apt:ssh|apt:ssh-keygen) pkg="openssh-client" ;;
      apt:systemctl) pkg="systemd" ;;
      dnf:ssh|dnf:ssh-keygen|yum:ssh|yum:ssh-keygen|zypper:ssh|zypper:ssh-keygen|pacman:ssh|pacman:ssh-keygen|apk:ssh|apk:ssh-keygen) pkg="openssh" ;;
      dnf:systemctl|yum:systemctl|zypper:systemctl|pacman:systemctl|apk:systemctl) pkg="systemd" ;;
    esac
    if [ -z "${seen[$pkg]+x}" ]; then
      seen["$pkg"]=1
      packages+=("$pkg")
    fi
  done
  echo "${packages[*]}"
}

install_missing_dependencies() {
  local missing_cmds=("$@")
  local pkg_manager packages_line
  local -a packages

  pkg_manager="$(detect_pkg_manager)"
  if [ -z "$pkg_manager" ]; then
    ui_err "Could not detect a supported package manager."
    ui_info "Install these commands manually, then rerun install: ${missing_cmds[*]}"
    return 1
  fi

  packages_line="$(map_cmds_to_packages "$pkg_manager" "${missing_cmds[@]}")"
  # shellcheck disable=SC2206
  packages=($packages_line)
  if [ "${#packages[@]}" -eq 0 ]; then
    ui_err "Unable to map missing commands to installable packages."
    ui_info "Missing commands: ${missing_cmds[*]}"
    return 1
  fi

  ui_warn "Missing dependencies detected: ${missing_cmds[*]}"
  case "$pkg_manager" in
    apt) ui_info "Suggested command: apt-get update && apt-get install -y ${packages[*]}" ;;
    dnf) ui_info "Suggested command: dnf install -y ${packages[*]}" ;;
    yum) ui_info "Suggested command: yum install -y ${packages[*]}" ;;
    zypper) ui_info "Suggested command: zypper --non-interactive install ${packages[*]}" ;;
    pacman) ui_info "Suggested command: pacman -Sy --noconfirm ${packages[*]}" ;;
    apk) ui_info "Suggested command: apk add --no-cache ${packages[*]}" ;;
    *) ui_err "Unsupported package manager: $pkg_manager"; return 1 ;;
  esac

  if ! prompt_yes_no "Install missing dependencies now?" "y"; then
    ui_warn "Install aborted. Install missing dependencies and rerun."
    return 1
  fi

  case "$pkg_manager" in
    apt)
      apt-get update
      apt-get install -y "${packages[@]}"
      ;;
    dnf) dnf install -y "${packages[@]}" ;;
    yum) yum install -y "${packages[@]}" ;;
    zypper) zypper --non-interactive install "${packages[@]}" ;;
    pacman) pacman -Sy --noconfirm "${packages[@]}" ;;
    apk) apk add --no-cache "${packages[@]}" ;;
  esac
}

preflight_checks() {
  local missing=0
  local c
  local -a missing_cmds=()
  for c in bash git curl ssh ssh-keygen; do
    if command -v "$c" >/dev/null 2>&1; then
      ui_ok "dependency: $c"
    else
      ui_err "dependency missing: $c"
      missing=1
      missing_cmds+=("$c")
    fi
  done
  if is_test_mode; then
    ui_warn "PA_TEST_MODE=true -> skipping hard dependency check for systemctl."
  else
    if command -v systemctl >/dev/null 2>&1; then
      ui_ok "dependency: systemctl"
    else
      ui_err "dependency missing: systemctl"
      missing=1
      missing_cmds+=("systemctl")
    fi
  fi
  if [ "$missing" -ne 0 ]; then
    install_missing_dependencies "${missing_cmds[@]}" || return 1
    preflight_checks
    return 0
  fi
}

require_root() {
  if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    ui_err "This command must be run as root."
    exit 1
  fi
}

write_runtime_version() {
  local v="$1"
  # Runtime version file is generated from repo VERSION during install/upgrade.
  cat > "$PCG_RUNTIME_VERSION_FILE" <<EOF
#!/bin/bash
AGENT_VERSION="$v"
export AGENT_VERSION
EOF
  chmod 755 "$PCG_RUNTIME_VERSION_FILE"
}

generate_ssh_key_if_missing() {
  if [ -f "$PCG_SSH_PRIVATE_KEY" ] && [ -f "$PCG_SSH_PUBLIC_KEY" ]; then
    ui_ok "Using existing SSH keypair."
    ui_info "Private key: $PCG_SSH_PRIVATE_KEY"
    ui_info "Public key:  $PCG_SSH_PUBLIC_KEY"
    return 0
  fi

  mkdir -p /root/.ssh
  chmod 700 /root/.ssh

  if [ -f "$PCG_SSH_PRIVATE_KEY" ] && [ ! -f "$PCG_SSH_PUBLIC_KEY" ]; then
    ui_warn "Private key exists but public key is missing. Regenerating public key..."
    ssh-keygen -y -f "$PCG_SSH_PRIVATE_KEY" > "$PCG_SSH_PUBLIC_KEY"
    chmod 644 "$PCG_SSH_PUBLIC_KEY"
    ui_ok "Generated public key from existing private key."
    ui_info "Private key: $PCG_SSH_PRIVATE_KEY"
    ui_info "Public key:  $PCG_SSH_PUBLIC_KEY"
    return 0
  fi

  if [ ! -f "$PCG_SSH_PRIVATE_KEY" ]; then
    ui_warn "No SSH key found at $PCG_SSH_PRIVATE_KEY. Generating a new SSH keypair..."
    mkdir -p /root/.ssh
    chmod 700 /root/.ssh
    ui_info "Generating SSH keypair..."
    ssh-keygen -t ed25519 -C "proxmox-agent" -f "$PCG_SSH_PRIVATE_KEY" -N ""
    chmod 600 "$PCG_SSH_PRIVATE_KEY"
    chmod 644 "$PCG_SSH_PUBLIC_KEY"
    ui_ok "Created SSH keypair."
    ui_info "Private key: $PCG_SSH_PRIVATE_KEY"
    ui_info "Public key:  $PCG_SSH_PUBLIC_KEY"
  fi
  return 0
}

is_ssh_remote_url() {
  local remote_url="${1:-}"
  [[ "$remote_url" =~ ^git@ ]] || [[ "$remote_url" =~ ^ssh:// ]]
}

is_https_remote_url() {
  local remote_url="${1:-}"
  [[ "$remote_url" =~ ^https:// ]]
}

is_supported_remote_url() {
  local remote_url="${1:-}"
  is_ssh_remote_url "$remote_url" || is_https_remote_url "$remote_url"
}

is_github_remote_url() {
  local remote_url="${1:-}"
  [[ "$remote_url" =~ ^git@github\.com:[A-Za-z0-9._-]+/[A-Za-z0-9._-]+(\.git)?$ ]] && return 0
  [[ "$remote_url" =~ ^ssh://git@github\.com/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+(\.git)?/?$ ]] && return 0
  [[ "$remote_url" =~ ^https://github\.com/[A-Za-z0-9._-]+/[A-Za-z0-9._-]+(\.git)?/?$ ]] && return 0
  return 1
}

mask_secret_value() {
  local v="${1:-}"
  if [ -z "$v" ]; then
    echo "unset"
  else
    echo "set (${#v} chars)"
  fi
}

save_install_draft() {
  local repo_dir="$1"
  local repo_branch="$2"
  local remote_url="$3"
  local retention_days="$4"
  local git_commit_name="$5"
  local git_commit_email="$6"
  local notify_mode="$7"
  local bot_token="$8"
  local chat_id="$9"
  local webhook_url="${10}"
  local webhook_token="${11}"

  cat > "$PCG_ENV_DRAFT" <<EOF
DRAFT_REPO_DIR=$(printf "%q" "$repo_dir")
DRAFT_REPO_BRANCH=$(printf "%q" "$repo_branch")
DRAFT_GIT_REMOTE_URL=$(printf "%q" "$remote_url")
DRAFT_PCG_LOG_RETENTION_DAYS=$(printf "%q" "$retention_days")
DRAFT_GIT_COMMIT_NAME=$(printf "%q" "$git_commit_name")
DRAFT_GIT_COMMIT_EMAIL=$(printf "%q" "$git_commit_email")
DRAFT_NOTIFY_MODE=$(printf "%q" "$notify_mode")
DRAFT_BOT_TOKEN=$(printf "%q" "$bot_token")
DRAFT_CHAT_ID=$(printf "%q" "$chat_id")
DRAFT_WEBHOOK_URL=$(printf "%q" "$webhook_url")
DRAFT_WEBHOOK_BEARER_TOKEN=$(printf "%q" "$webhook_token")
EOF
  chmod 600 "$PCG_ENV_DRAFT"
}

load_install_draft() {
  if [ -f "$PCG_ENV_DRAFT" ]; then
    # shellcheck disable=SC1090
    source "$PCG_ENV_DRAFT"
    return 0
  fi
  return 1
}

clear_install_draft() {
  rm -f "$PCG_ENV_DRAFT"
}

validate_guided_inputs() {
  local repo_dir="$1"
  local repo_branch="$2"
  local remote_url="$3"
  local git_commit_name="$4"
  local git_commit_email="$5"
  local notify_mode="$6"
  local bot_token="$7"
  local chat_id="$8"
  local webhook_url="$9"

  local failed=0
  echo
  echo "${C_BOLD}Final Validation Checklist${C_RESET}"

  if [ -n "$repo_dir" ]; then ui_ok "repo_dir configured ($repo_dir)"; else ui_err "repo_dir is required"; failed=1; fi
  if [ -n "$repo_branch" ]; then ui_ok "repo_branch configured ($repo_branch)"; else ui_err "repo_branch is required"; failed=1; fi
  if [ -n "$git_commit_name" ]; then
    ui_ok "git commit author name configured"
  else
    ui_err "git commit author name is required"
    failed=1
  fi
  if [[ -n "$git_commit_email" && "$git_commit_email" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]]; then
    ui_ok "git commit author email configured"
  else
    ui_err "git commit author email is required and must be valid (name@example.com)"
    failed=1
  fi
  if is_supported_remote_url "$remote_url"; then
    if is_ssh_remote_url "$remote_url"; then
      ui_ok "git_remote_url format valid (SSH)"
    else
      ui_ok "git_remote_url format valid (HTTPS)"
    fi
    if is_github_remote_url "$remote_url"; then
      ui_ok "git_remote_url target valid (github.com owner/repo)"
    else
      ui_err "git_remote_url must be a GitHub repository URL (github.com/OWNER/REPO)"
      failed=1
    fi
  else
    ui_err "git_remote_url must be SSH or HTTPS"
    failed=1
  fi

  case "$notify_mode" in
    telegram|webhook|both|later) ui_ok "notification mode selected: $notify_mode" ;;
    *) ui_err "notification mode must be telegram, webhook, both, or later"; failed=1 ;;
  esac

  if [ "$notify_mode" = "telegram" ] || [ "$notify_mode" = "both" ]; then
    if [ -n "$bot_token" ] && [ -n "$chat_id" ]; then
      ui_ok "telegram configuration complete"
    else
      ui_err "telegram mode requires BOT_TOKEN and CHAT_ID"
      failed=1
    fi
  fi

  if [ "$notify_mode" = "webhook" ] || [ "$notify_mode" = "both" ]; then
    if [[ -n "$webhook_url" && "$webhook_url" =~ ^https?:// ]]; then
      ui_ok "webhook configuration complete"
    else
      ui_err "webhook mode requires a valid WEBHOOK_URL"
      failed=1
    fi
  fi

  if [ "$notify_mode" = "later" ]; then
    ui_warn "Placeholder notification mode selected; continuing without active notification validation."
  fi

  if [ "$failed" -eq 0 ]; then
    ui_ok "All validation checks passed."
    return 0
  fi
  ui_err "Validation failed. Please correct the inputs."
  return 1
}

print_guided_input_summary() {
  local repo_dir="$1"
  local repo_branch="$2"
  local remote_url="$3"
  local retention_days="$4"
  local git_commit_name="$5"
  local git_commit_email="$6"
  local notify_mode="$7"
  local bot_token="$8"
  local chat_id="$9"
  local webhook_url="${10}"
  local webhook_token="${11}"
  local remote_mode="HTTPS"
  is_ssh_remote_url "$remote_url" && remote_mode="SSH"

  echo
  echo "${C_BOLD}Settings Summary${C_RESET}"
  echo "  - REPO_DIR: $repo_dir"
  echo "  - REPO_BRANCH: $repo_branch"
  echo "  - GIT_REMOTE_URL: $remote_url"
  echo "  - Remote auth mode: $remote_mode"
  echo "  - PCG_LOG_RETENTION_DAYS: $retention_days"
  echo "  - GIT_COMMIT_NAME: $git_commit_name"
  echo "  - GIT_COMMIT_EMAIL: $git_commit_email"
  echo "  - Notification mode: $notify_mode"
  if [ "$notify_mode" = "telegram" ] || [ "$notify_mode" = "both" ]; then
    echo "  - BOT_TOKEN: $(mask_secret_value "$bot_token")"
    echo "  - CHAT_ID: $chat_id"
  fi
  if [ "$notify_mode" = "webhook" ] || [ "$notify_mode" = "both" ]; then
    echo "  - WEBHOOK_URL: $webhook_url"
    echo "  - WEBHOOK_BEARER_TOKEN: $(mask_secret_value "$webhook_token")"
  fi
  if [ "$notify_mode" = "later" ]; then
    echo "  - BOT_TOKEN: $(mask_secret_value "$bot_token")"
    echo "  - CHAT_ID: $chat_id"
    echo "  - WEBHOOK_URL: $webhook_url"
    echo "  - WEBHOOK_BEARER_TOKEN: $(mask_secret_value "$webhook_token")"
    echo "  - WEBHOOK_ENABLED: $webhook_enabled"
  fi
}

print_repo_url_guidance() {
  echo "  - Create an empty GitHub repository first (or use an existing one)."
  echo "  - Then provide one of these remote URL formats:"
  echo "    * SSH:   git@github.com:OWNER/REPO.git"
  echo "    * HTTPS: https://github.com/OWNER/REPO.git"
}

show_public_key_for_github() {
  if [ -f "$PCG_SSH_PUBLIC_KEY" ]; then
    ui_info "GitHub SSH key setup instructions:"
    echo "  1) Open: https://github.com/settings/keys"
    echo "  2) Click: New SSH key"
    echo "  3) Paste the full OpenSSH public key shown below"
    echo "  4) Save, then return here to continue"
    echo
    ui_info "Private key location: $PCG_SSH_PRIVATE_KEY"
    ui_info "Public key location:  $PCG_SSH_PUBLIC_KEY"
    ui_info "OpenSSH public key content:"
    echo "----- BEGIN OPENSSH PUBLIC KEY -----"
    cat "$PCG_SSH_PUBLIC_KEY"
    echo "----- END OPENSSH PUBLIC KEY -----"
    echo
  else
    ui_warn "Public key file not found at $PCG_SSH_PUBLIC_KEY"
    return 1
  fi
  return 0
}

validate_github_ssh() {
  if is_test_mode; then
    return 0
  fi
  local output
  set +e
  output="$(ssh -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 -T git@github.com 2>&1)"
  set -e
  echo "$output" | grep -qi "successfully authenticated"
}

guided_env_setup() {
  local force_resume="${1:-0}"
  [ -f "$PCG_ENV_TARGET" ] || install -m 600 "$PCG_ENV_EXAMPLE_SOURCE" "$PCG_ENV_TARGET"
  pcg_load_env

  local repo_dir repo_branch remote_url retention_days
  local git_commit_name git_commit_email
  local notify_mode bot_token chat_id webhook_enabled webhook_url webhook_token

  repo_dir="${REPO_DIR:-/root/pve-config}"
  repo_branch="${REPO_BRANCH:-main}"
  remote_url="${GIT_REMOTE_URL:-}"
  retention_days="${PCG_LOG_RETENTION_DAYS:-14}"
  git_commit_name="${GIT_COMMIT_NAME:-}"
  git_commit_email="${GIT_COMMIT_EMAIL:-}"
  notify_mode="telegram"
  bot_token="${BOT_TOKEN:-}"
  chat_id="${CHAT_ID:-}"
  webhook_enabled="false"
  webhook_url="${WEBHOOK_URL:-}"
  webhook_token="${WEBHOOK_BEARER_TOKEN:-}"

  if [ -f "$PCG_ENV_DRAFT" ]; then
    ui_info "Saved installer settings found: $PA_ENV_DRAFT"
    if [ "$force_resume" -eq 1 ]; then
      if load_install_draft; then
        repo_dir="${DRAFT_REPO_DIR:-$repo_dir}"
        repo_branch="${DRAFT_REPO_BRANCH:-$repo_branch}"
        remote_url="${DRAFT_GIT_REMOTE_URL:-$remote_url}"
        retention_days="${DRAFT_PCG_LOG_RETENTION_DAYS:-$retention_days}"
        git_commit_name="${DRAFT_GIT_COMMIT_NAME:-$git_commit_name}"
        git_commit_email="${DRAFT_GIT_COMMIT_EMAIL:-$git_commit_email}"
        notify_mode="${DRAFT_NOTIFY_MODE:-$notify_mode}"
        bot_token="${DRAFT_BOT_TOKEN:-$bot_token}"
        chat_id="${DRAFT_CHAT_ID:-$chat_id}"
        webhook_url="${DRAFT_WEBHOOK_URL:-$webhook_url}"
        webhook_token="${DRAFT_WEBHOOK_BEARER_TOKEN:-$webhook_token}"
        ui_ok "Loaded saved settings (resume mode)."
        print_guided_input_summary "$repo_dir" "$repo_branch" "$remote_url" "$retention_days" "$git_commit_name" "$git_commit_email" "$notify_mode" "$bot_token" "$chat_id" "$webhook_url" "$webhook_token"
        ui_info "Reconfirm and edit any values in the next prompts."
      else
        ui_warn "Could not load saved installer settings file."
      fi
    elif prompt_yes_no "Load saved settings and continue?" "y"; then
      if load_install_draft; then
        repo_dir="${DRAFT_REPO_DIR:-$repo_dir}"
        repo_branch="${DRAFT_REPO_BRANCH:-$repo_branch}"
        remote_url="${DRAFT_GIT_REMOTE_URL:-$remote_url}"
        retention_days="${DRAFT_PCG_LOG_RETENTION_DAYS:-$retention_days}"
        git_commit_name="${DRAFT_GIT_COMMIT_NAME:-$git_commit_name}"
        git_commit_email="${DRAFT_GIT_COMMIT_EMAIL:-$git_commit_email}"
        notify_mode="${DRAFT_NOTIFY_MODE:-$notify_mode}"
        bot_token="${DRAFT_BOT_TOKEN:-$bot_token}"
        chat_id="${DRAFT_CHAT_ID:-$chat_id}"
        webhook_url="${DRAFT_WEBHOOK_URL:-$webhook_url}"
        webhook_token="${DRAFT_WEBHOOK_BEARER_TOKEN:-$webhook_token}"
        ui_ok "Loaded saved settings."
        print_guided_input_summary "$repo_dir" "$repo_branch" "$remote_url" "$retention_days" "$git_commit_name" "$git_commit_email" "$notify_mode" "$bot_token" "$chat_id" "$webhook_url" "$webhook_token"
        ui_info "Reconfirm and edit any values in the next prompts."
      else
        ui_warn "Could not load saved installer settings file."
      fi
    fi
  fi

  ui_info "Configure backup repository settings."
  ui_info "GitHub setup guidance:"
  print_repo_url_guidance
  ui_info "Preparing node SSH public key for GitHub copy/paste..."
  generate_ssh_key_if_missing || true
  show_public_key_for_github || true
  remote_url="$(prompt_value "Git remote URL (SSH or HTTPS)" "$remote_url")"
  while true; do
    if [ -z "$remote_url" ]; then
      ui_warn "Git remote URL is required for automated backup pushes."
      print_repo_url_guidance
      remote_url="$(prompt_value "Git remote URL (SSH or HTTPS)" "")"
      continue
    fi
    if ! is_supported_remote_url "$remote_url"; then
      ui_warn "Remote URL must be SSH (git@... or ssh://...) or HTTPS (https://...)."
      print_repo_url_guidance
      remote_url="$(prompt_value "Git remote URL (SSH or HTTPS)" "")"
      continue
    fi
    if ! is_github_remote_url "$remote_url"; then
      ui_warn "Remote URL must target github.com in OWNER/REPO format."
      print_repo_url_guidance
      remote_url="$(prompt_value "Git remote URL (SSH or HTTPS)" "")"
      continue
    fi
    break
  done
  if is_ssh_remote_url "$remote_url"; then
    ui_ok "GitHub remote URL accepted (SSH)."
    ui_info "Validating GitHub SSH authentication before continuing."
    if ! guided_github_auth "$remote_url"; then
      return 1
    fi
  else
    ui_ok "GitHub remote URL accepted (HTTPS)."
    ui_info "HTTPS remote selected; SSH key/auth validation skipped."
  fi
  repo_dir="$(prompt_value "Backup local repo directory" "$repo_dir")"
  repo_branch="$(prompt_value "Backup git branch" "$repo_branch")"
  retention_days="$(prompt_value "Log retention days" "$retention_days")"
  git_commit_name="$(prompt_value "Git commit author full name" "$git_commit_name")"
  while [ -z "$git_commit_name" ]; do
    ui_warn "Git commit author full name is required."
    git_commit_name="$(prompt_value "Git commit author full name" "$git_commit_name")"
  done
  git_commit_email="$(prompt_value "Git commit author email" "$git_commit_email")"
  while [[ -z "$git_commit_email" || ! "$git_commit_email" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]]; do
    ui_warn "A valid commit author email is required (example: name@example.com)."
    git_commit_email="$(prompt_value "Git commit author email" "$git_commit_email")"
  done

  ui_info "Configure notifications."
  ui_info "Choose your notification setup."
  case "$notify_mode" in
    telegram|webhook|both|later) ;;
    *) notify_mode="telegram" ;;
  esac
  notify_mode="$(prompt_notification_mode "$notify_mode")"

  if [ "$notify_mode" = "telegram" ] || [ "$notify_mode" = "both" ]; then
    bot_token="$(prompt_value "Telegram BOT_TOKEN" "$bot_token")"
    chat_id="$(prompt_value "Telegram CHAT_ID (Telegram ID)" "$chat_id")"
    while [ -z "$bot_token" ] || [ -z "$chat_id" ]; do
      ui_warn "BOT_TOKEN and CHAT_ID are required when Telegram is enabled."
      bot_token="$(prompt_value "Telegram BOT_TOKEN" "$bot_token")"
      chat_id="$(prompt_value "Telegram CHAT_ID (Telegram ID)" "$chat_id")"
    done
  else
    bot_token=""
    chat_id=""
  fi

  if [ "$notify_mode" = "webhook" ] || [ "$notify_mode" = "both" ]; then
    webhook_enabled="true"
    webhook_url="$(prompt_value "Webhook URL (https://...)" "$webhook_url")"
    while [[ -z "$webhook_url" || ! "$webhook_url" =~ ^https?:// ]]; do
      ui_warn "A valid webhook URL is required when webhook is enabled."
      webhook_url="$(prompt_value "Webhook URL (https://...)" "$webhook_url")"
    done
    webhook_token="$(prompt_value "Webhook bearer token (optional)" "$webhook_token")"
  else
    webhook_enabled="false"
    webhook_url=""
    webhook_token=""
  fi

  if [ "$notify_mode" = "later" ]; then
    bot_token="PCG_PLACEHOLDER_BOT_TOKEN"
    chat_id="PCG_PLACEHOLDER_CHAT_ID"
    webhook_enabled="false"
    webhook_url="https://example.com/your-webhook-endpoint"
    webhook_token="PCG_PLACEHOLDER_WEBHOOK_TOKEN"
    ui_warn "Placeholder values will be saved. Update /root/.pcg-agent.env before enabling notifications."
  fi

  print_guided_input_summary "$repo_dir" "$repo_branch" "$remote_url" "$retention_days" "$git_commit_name" "$git_commit_email" "$notify_mode" "$bot_token" "$chat_id" "$webhook_url" "$webhook_token"
  if ! validate_guided_inputs "$repo_dir" "$repo_branch" "$remote_url" "$git_commit_name" "$git_commit_email" "$notify_mode" "$bot_token" "$chat_id" "$webhook_url"; then
    return 1
  fi

  local final_action
  final_action="$(prompt_final_action "install")"
  case "$final_action" in
    save)
      save_install_draft "$repo_dir" "$repo_branch" "$remote_url" "$retention_days" "$git_commit_name" "$git_commit_email" "$notify_mode" "$bot_token" "$chat_id" "$webhook_url" "$webhook_token"
      ui_ok "Settings saved to $PCG_ENV_DRAFT"
      ui_info "Resume with: pcg install --resume"
      return 2
      ;;
    exit)
      ui_warn "Install cancelled before applying environment settings."
      return 2
      ;;
    install)
      ;;
  esac

  set_env_kv "$PCG_ENV_TARGET" "REPO_DIR" "$repo_dir"
  set_env_kv "$PCG_ENV_TARGET" "REPO_BRANCH" "$repo_branch"
  set_env_kv "$PCG_ENV_TARGET" "GIT_REMOTE_URL" "$remote_url"
  set_env_kv "$PCG_ENV_TARGET" "PCG_LOG_RETENTION_DAYS" "$retention_days"
  set_env_kv "$PCG_ENV_TARGET" "GIT_COMMIT_NAME" "$git_commit_name"
  set_env_kv "$PCG_ENV_TARGET" "GIT_COMMIT_EMAIL" "$git_commit_email"
  set_env_kv "$PCG_ENV_TARGET" "BOT_TOKEN" "$bot_token"
  set_env_kv "$PCG_ENV_TARGET" "CHAT_ID" "$chat_id"
  set_env_kv "$PCG_ENV_TARGET" "WEBHOOK_ENABLED" "$webhook_enabled"
  set_env_kv "$PCG_ENV_TARGET" "WEBHOOK_URL" "$webhook_url"
  set_env_kv "$PCG_ENV_TARGET" "WEBHOOK_BEARER_TOKEN" "$webhook_token"

  chmod 600 "$PCG_ENV_TARGET"
  clear_install_draft
  pcg_load_env
}

guided_github_auth() {
  local remote_url="${1:-}"
  if ! is_ssh_remote_url "$remote_url"; then
    ui_info "HTTPS remote detected; skipping SSH key setup/validation."
    return 0
  fi

  if is_test_mode; then
    ui_warn "PCG_TEST_MODE=true -> skipping interactive GitHub SSH validation."
    return 0
  fi
  if ! generate_ssh_key_if_missing; then
    return 1
  fi
  # Always show the current OpenSSH public key so users can copy it to GitHub.
  show_public_key_for_github
  ui_info "Checking GitHub SSH authentication."
  while true; do
    if validate_github_ssh; then
      ui_ok "GitHub SSH authentication is valid."
      return 0
    fi

    ui_warn "GitHub SSH authentication failed."
    show_public_key_for_github
    if prompt_yes_no "Open GitHub, add the key, and retry SSH validation now?" "y"; then
      continue
    fi
    return 1
  done
}

build_preinstall_actions() {
  PRE_ACTIONS=()
  PRE_ACTIONS+=("Install canonical pcg-* scripts into /usr/local/bin")
  PRE_ACTIONS+=("Install canonical pcg-* systemd units into /etc/systemd/system")
  PRE_ACTIONS+=("Generate runtime version file /usr/local/bin/pcg-agent-version from repo VERSION")
  PRE_ACTIONS+=("Enable and start pcg-backup-config.timer; enable pcg-shutdown-proxmox.service and pcg-boot-notify.service")
  PRE_ACTIONS+=("Run post-install doctor validation")

  if [ -f "$PCG_ENV_LEGACY" ] && [ ! -f "$PCG_ENV_TARGET" ]; then
    PRE_ACTIONS+=("Migrate env file from $PCG_ENV_LEGACY to $PCG_ENV_TARGET")
  fi
  if detect_legacy_artifacts; then
    PRE_ACTIONS+=("Stop and disable legacy units (backup-config*, proxmox-bootup-telegram, shutdown-proxmox)")
    PRE_ACTIONS+=("Remove legacy managed files after successful migration")
  fi
  if [ ! -f /root/.ssh/id_ed25519 ]; then
    PRE_ACTIONS+=("Generate SSH keypair /root/.ssh/id_ed25519 for Git auth")
  fi
}

collect_preinstall_report_data() {
  PRE_BLOCKERS=()
  PRE_WARNINGS=()
  PRE_NOTES=()
  PRE_DEPS_OK=()
  PRE_DEPS_MISSING=()
  PRE_LEGACY_UNITS_PRESENT=()
  PRE_CANONICAL_UNITS_PRESENT=()

  local dep
  for dep in bash git curl ssh ssh-keygen; do
    if command -v "$dep" >/dev/null 2>&1; then
      PRE_DEPS_OK+=("$dep")
    else
      PRE_DEPS_MISSING+=("$dep")
    fi
  done
  if ! is_test_mode; then
    if command -v systemctl >/dev/null 2>&1; then
      PRE_DEPS_OK+=("systemctl")
    else
      PRE_DEPS_MISSING+=("systemctl")
    fi
  fi
  if [ "${#PRE_DEPS_MISSING[@]}" -gt 0 ]; then
    PRE_BLOCKERS+=("Missing dependencies: ${PRE_DEPS_MISSING[*]}")
  fi

  if [ -f "$PA_RUNTIME_VERSION_FILE" ]; then
    PRE_INSTALL_STATE="canonical"
  elif detect_legacy_artifacts; then
    PRE_INSTALL_STATE="legacy"
  else
    PRE_INSTALL_STATE="none"
  fi

  PRE_CURRENT_VERSION="unknown"
  if [ -f "$PCG_RUNTIME_VERSION_FILE" ]; then
    # shellcheck disable=SC1090
    source "$PCG_RUNTIME_VERSION_FILE" || true
    PRE_CURRENT_VERSION="${AGENT_VERSION:-unknown}"
  elif [ -f "$PCG_RUNTIME_VERSION_LEGACY" ]; then
    # shellcheck disable=SC1090
    source "$PCG_RUNTIME_VERSION_LEGACY" || true
    PRE_CURRENT_VERSION="${AGENT_VERSION:-unknown}"
  fi

  PRE_ENV_SOURCE="missing"
  if [ -f "$PCG_ENV_TARGET" ]; then
    PRE_ENV_SOURCE="$PCG_ENV_TARGET"
  elif [ -f "$PCG_ENV_LEGACY" ]; then
    PRE_ENV_SOURCE="$PCG_ENV_LEGACY"
  fi

  pcg_load_env
  [ -n "${REPO_DIR:-}" ] || PRE_WARNINGS+=("REPO_DIR not set (default /root/pve-config will be used)")
  [ -n "${REPO_BRANCH:-}" ] || PRE_WARNINGS+=("REPO_BRANCH not set (default main will be used)")
  [ -n "${GIT_COMMIT_NAME:-}" ] || PRE_WARNINGS+=("GIT_COMMIT_NAME not set (installer will prompt for commit author name)")
  if [ -z "${GIT_COMMIT_EMAIL:-}" ]; then
    PRE_WARNINGS+=("GIT_COMMIT_EMAIL not set (installer will prompt for commit author email)")
  elif [[ ! "${GIT_COMMIT_EMAIL:-}" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]]; then
    PRE_WARNINGS+=("GIT_COMMIT_EMAIL format looks invalid (installer will require a valid email)")
  fi
  if [ -z "${GIT_REMOTE_URL:-}" ]; then
    PRE_BLOCKERS+=("GIT_REMOTE_URL is not configured")
  fi

  if is_test_mode; then
    PRE_NOTES+=("PCG_TEST_MODE=true; GitHub SSH and systemctl enforcement are relaxed for test runs")
  elif is_ssh_remote_url "${GIT_REMOTE_URL:-}" && ! validate_github_ssh; then
    PRE_WARNINGS+=("GitHub SSH auth is not currently valid; installer will guide key setup/retry")
  fi

  local u
  for u in "${PCG_LEGACY_UNIT_FILES[@]}"; do
    [ -f "$PCG_SYSTEMD_TARGET/$u" ] && PRE_LEGACY_UNITS_PRESENT+=("$u")
  done
  for u in "${PCG_CANONICAL_UNIT_FILES[@]}"; do
    [ -f "$PCG_SYSTEMD_TARGET/$u" ] && PRE_CANONICAL_UNITS_PRESENT+=("$u")
  done

  PRE_NOTES+=("Env file in use for current settings: $PRE_ENV_SOURCE")
  PRE_NOTES+=("Detected install state: $PRE_INSTALL_STATE")
  PRE_NOTES+=("Detected installed version: $PRE_CURRENT_VERSION")
}

print_preinstall_report_text() {
  echo "${C_BOLD}Preinstall Simulation Report${C_RESET}"
  ui_info "This command is read-only and makes no system changes."
  echo
  echo "Current state:"
  echo "  - install_state: $PRE_INSTALL_STATE"
  echo "  - installed_version: $PRE_CURRENT_VERSION"
  echo "  - env_source: $PRE_ENV_SOURCE"
  echo "  - legacy_units_present: ${#PRE_LEGACY_UNITS_PRESENT[@]}"
  echo "  - canonical_units_present: ${#PRE_CANONICAL_UNITS_PRESENT[@]}"
  echo
  echo "What installer will change:"
  local item
  for item in "${PRE_ACTIONS[@]}"; do
    echo "  - $item"
  done
  echo
  if [ "${#PRE_BLOCKERS[@]}" -gt 0 ]; then
    echo "Blockers:"
    for item in "${PRE_BLOCKERS[@]}"; do
      echo "  - $item"
    done
    echo
  fi
  if [ "${#PRE_WARNINGS[@]}" -gt 0 ]; then
    echo "Warnings:"
    for item in "${PRE_WARNINGS[@]}"; do
      echo "  - $item"
    done
    echo
  fi
  if [ "${#PRE_NOTES[@]}" -gt 0 ]; then
    echo "Notes:"
    for item in "${PRE_NOTES[@]}"; do
      echo "  - $item"
    done
  fi
}

print_preinstall_report_json() {
  local first
  printf '{"read_only":true'
  printf ',"install_state":"%s"' "$(pa_json_escape "$PRE_INSTALL_STATE")"
  printf ',"installed_version":"%s"' "$(pa_json_escape "$PRE_CURRENT_VERSION")"
  printf ',"env_source":"%s"' "$(pa_json_escape "$PRE_ENV_SOURCE")"
  printf ',"legacy_units_present":['
  first=1
  local item
  for item in "${PRE_LEGACY_UNITS_PRESENT[@]}"; do
    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '"%s"' "$(pa_json_escape "$item")"
  done
  printf ']'
  printf ',"planned_actions":['
  first=1
  for item in "${PRE_ACTIONS[@]}"; do
    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '"%s"' "$(pa_json_escape "$item")"
  done
  printf ']'
  printf ',"blockers":['
  first=1
  for item in "${PRE_BLOCKERS[@]}"; do
    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '"%s"' "$(pa_json_escape "$item")"
  done
  printf ']'
  printf ',"warnings":['
  first=1
  for item in "${PRE_WARNINGS[@]}"; do
    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '"%s"' "$(pa_json_escape "$item")"
  done
  printf ']'
  printf ',"notes":['
  first=1
  for item in "${PRE_NOTES[@]}"; do
    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '"%s"' "$(pa_json_escape "$item")"
  done
  printf ']}'
  echo
}

cmd_preinstall_report() {
  local json=0
  if [ "${1:-}" = "--json" ]; then
    json=1
  fi
  collect_preinstall_report_data
  build_preinstall_actions
  if [ "$json" -eq 1 ]; then
    print_preinstall_report_json
  else
    print_preinstall_report_text
  fi
  [ "${#PRE_BLOCKERS[@]}" -eq 0 ]
}

configure_repo_remote_if_needed() {
  local repo_dir branch remote_from_env repo_created remote_action git_commit_name git_commit_email
  pa_load_env
  repo_dir="${REPO_DIR:-/root/pve-config}"
  branch="${REPO_BRANCH:-main}"
  remote_from_env="${GIT_REMOTE_URL:-}"
  git_commit_name="${GIT_COMMIT_NAME:-}"
  git_commit_email="${GIT_COMMIT_EMAIL:-}"
  repo_created=0
  remote_action="none"

  ui_info "Preparing local git workspace: $repo_dir"
  mkdir -p "$repo_dir"
  if [ ! -d "$repo_dir/.git" ]; then
    git -C "$repo_dir" init -b "$branch"
    repo_created=1
  fi

  if [ -n "$remote_from_env" ]; then
    if git -C "$repo_dir" remote get-url origin >/dev/null 2>&1; then
      git -C "$repo_dir" remote set-url origin "$remote_from_env"
      remote_action="updated"
    else
      git -C "$repo_dir" remote add origin "$remote_from_env"
      remote_action="added"
    fi
  fi

  if [ -n "$git_commit_name" ]; then
    git -C "$repo_dir" config user.name "$git_commit_name"
  fi
  if [ -n "$git_commit_email" ]; then
    git -C "$repo_dir" config user.email "$git_commit_email"
  fi

  if [ "$repo_created" -eq 1 ]; then
    ui_ok "Initialized git repository at $repo_dir (branch $branch)."
  else
    ui_ok "Using existing git repository at $repo_dir."
  fi
  case "$remote_action" in
    added) ui_ok "Configured git remote 'origin' -> $remote_from_env" ;;
    updated) ui_ok "Updated git remote 'origin' -> $remote_from_env" ;;
  esac
  if [ -n "$git_commit_name" ] && [ -n "$git_commit_email" ]; then
    ui_ok "Configured git commit identity for $repo_dir ($git_commit_name <$git_commit_email>)."
  fi
}

validate_git_remote_access() {
  local repo_dir quiet
  quiet="${1:-0}"
  pa_load_env
  repo_dir="${REPO_DIR:-/root/pve-config}"

  if ! git -C "$repo_dir" remote get-url origin >/dev/null 2>&1; then
    [ "$quiet" = "1" ] || echo "Missing git origin remote in $repo_dir. Set GIT_REMOTE_URL in $PA_ENV_TARGET or add origin manually."
    return 1
  fi

  if ! git -C "$repo_dir" ls-remote origin >/dev/null 2>&1; then
    [ "$quiet" = "1" ] || echo "Cannot access git remote from $repo_dir."
    return 1
  fi

  return 0
}

detect_legacy_artifacts() {
  local f
  for f in "${PA_LEGACY_BIN_FILES[@]}"; do
    [ -e "$PA_BIN_TARGET/$f" ] && return 0
  done
  for f in "${PA_LEGACY_UNIT_FILES[@]}"; do
    [ -e "$PA_SYSTEMD_TARGET/$f" ] && return 0
  done
  [ -e "$PA_ENV_LEGACY" ] && return 0
  [ -e "$PA_RUNTIME_VERSION_LEGACY" ] && return 0
  return 1
}

count_legacy_artifacts() {
  local c=0 f
  for f in "${PA_LEGACY_BIN_FILES[@]}"; do [ -e "$PA_BIN_TARGET/$f" ] && c=$((c + 1)); done
  for f in "${PA_LEGACY_UNIT_FILES[@]}"; do [ -e "$PA_SYSTEMD_TARGET/$f" ] && c=$((c + 1)); done
  [ -e "$PA_ENV_LEGACY" ] && c=$((c + 1))
  [ -e "$PA_RUNTIME_VERSION_LEGACY" ] && c=$((c + 1))
  echo "$c"
}

capture_unit_states() {
  local backup_dir="$1"
  local unit
  : > "$backup_dir/unit-states.txt"
  for unit in "${PA_CANONICAL_UNIT_FILES[@]}" "${PA_LEGACY_UNIT_FILES[@]}"; do
    if systemctl is-enabled "$unit" >/dev/null 2>&1; then
      echo "$unit" >> "$backup_dir/unit-states.txt"
    fi
  done
}

disable_all_managed_units() {
  local unit
  for unit in "${PA_CANONICAL_UNIT_FILES[@]}" "${PA_LEGACY_UNIT_FILES[@]}"; do
    pa_systemctl stop "$unit" >/dev/null 2>&1 || true
    pa_systemctl disable "$unit" >/dev/null 2>&1 || true
  done
}

restore_unit_states() {
  local backup_dir="$1"
  local unit
  disable_all_managed_units
  if [ -f "$backup_dir/unit-states.txt" ]; then
    while IFS= read -r unit; do
      [ -n "$unit" ] || continue
      pa_systemctl enable "$unit" >/dev/null 2>&1 || true
      [[ "$unit" == *.timer ]] && pa_systemctl start "$unit" >/dev/null 2>&1 || true
    done < "$backup_dir/unit-states.txt"
  fi
}

cleanup_managed_artifacts() {
  local f
  for f in "${PCG_CANONICAL_BIN_FILES[@]}" "${PCG_LEGACY_BIN_FILES[@]}"; do
    rm -f "$PCG_BIN_TARGET/$f"
  done
  for f in "${PCG_CANONICAL_UNIT_FILES[@]}" "${PCG_LEGACY_UNIT_FILES[@]}"; do
    rm -f "$PCG_SYSTEMD_TARGET/$f"
  done
  rm -f "$PCG_ENV_TARGET" "$PCG_ENV_LEGACY"
}

backup_current_install() {
  local backup_dir="$1"
  local f
  mkdir -p "$backup_dir/bin" "$backup_dir/systemd" "$backup_dir/env"

  for f in "${PCG_CANONICAL_BIN_FILES[@]}" "${PCG_LEGACY_BIN_FILES[@]}"; do
    [ -f "$PCG_BIN_TARGET/$f" ] && cp -a "$PCG_BIN_TARGET/$f" "$backup_dir/bin/$f"
  done

  for f in "${PCG_CANONICAL_UNIT_FILES[@]}" "${PCG_LEGACY_UNIT_FILES[@]}"; do
    [ -f "$PCG_SYSTEMD_TARGET/$f" ] && cp -a "$PCG_SYSTEMD_TARGET/$f" "$backup_dir/systemd/$f"
  done

  [ -f "$PCG_ENV_TARGET" ] && cp -a "$PCG_ENV_TARGET" "$backup_dir/env/.pcg-agent.env"
  [ -f "$PCG_ENV_LEGACY" ] && cp -a "$PCG_ENV_LEGACY" "$backup_dir/env/.backup-config.env"

  capture_unit_states "$backup_dir"
}

restore_from_backup() {
  local backup_dir="$1"
  local f

  disable_all_managed_units
  cleanup_managed_artifacts

  for f in "$backup_dir"/bin/*; do
    [ -f "$f" ] || continue
    install -m 755 "$f" "$PCG_BIN_TARGET/$(basename "$f")"
  done
  for f in "$backup_dir"/systemd/*; do
    [ -f "$f" ] || continue
    install -m 644 "$f" "$PCG_SYSTEMD_TARGET/$(basename "$f")"
  done

  [ -f "$backup_dir/env/.pcg-agent.env" ] && install -m 600 "$backup_dir/env/.pcg-agent.env" "$PCG_ENV_TARGET"
  [ -f "$backup_dir/env/.backup-config.env" ] && install -m 600 "$backup_dir/env/.backup-config.env" "$PCG_ENV_LEGACY"

  pcg_systemctl daemon-reload
  restore_unit_states "$backup_dir"
}

migrate_env_file() {
  if [ ! -f "$PCG_ENV_TARGET" ] && [ -f "$PCG_ENV_LEGACY" ]; then
    cp -a "$PCG_ENV_LEGACY" "$PCG_ENV_TARGET"
    chmod 600 "$PCG_ENV_TARGET"
  fi
}

disable_legacy_units() {
  local unit
  for unit in "${PCG_LEGACY_UNIT_FILES[@]}"; do
    pcg_systemctl stop "$unit" >/dev/null 2>&1 || true
    pcg_systemctl disable "$unit" >/dev/null 2>&1 || true
  done
}

remove_legacy_artifacts() {
  local f
  for f in "${PCG_LEGACY_BIN_FILES[@]}"; do
    rm -f "$PCG_BIN_TARGET/$f"
  done
  for f in "${PCG_LEGACY_UNIT_FILES[@]}"; do
    rm -f "$PCG_SYSTEMD_TARGET/$f"
  done
  rm -f "$PCG_ENV_LEGACY" "$PCG_RUNTIME_VERSION_LEGACY"
}

perform_uninstall() {
  require_root
  local ts backup_dir
  ts="$(date +%Y%m%d-%H%M%S)"
  backup_dir="$PCG_BACKUP_DIR_BASE/uninstall-$ts"
  mkdir -p "$PCG_BACKUP_DIR_BASE"
  backup_current_install "$backup_dir"

  ui_warn "Uninstall will remove managed scripts, units, runtime version file, and env files."
  if ! prompt_yes_no "Proceed with uninstall?" "n"; then
    ui_warn "Uninstall cancelled by user."
    return 2
  fi

  disable_all_managed_units
  cleanup_managed_artifacts
  remove_legacy_artifacts
  clear_install_draft
  pa_systemctl daemon-reload

  ui_ok "Uninstall complete."
  ui_info "Backup snapshot saved at: $backup_dir"
  return 0
}

install_canonical_files_from_repo() {
  local f
  local bin_files=(
    "pcg-doctor.sh"
    "pcg-backup-config.sh"
    "pcg-boot-notify.sh"
    "pcg-send-telegram.sh"
    "pcg-send-webhook.sh"
    "pcg-shutdown-proxmox.sh"
    "pcg-agent-lib.sh"
    "pcg"
  )
  local unit_files=(
    "pcg-backup-config.service"
    "pcg-backup-config.timer"
    "pcg-boot-notify.service"
    "pcg-shutdown-proxmox.service"
  )

  mkdir -p "$PCG_BIN_TARGET" "$PCG_SYSTEMD_TARGET"

  for f in "${bin_files[@]}"; do
    install -m 755 "$REPO_ROOT/bin/$f" "$PCG_BIN_TARGET/$f"
  done
  for f in "${unit_files[@]}"; do
    install -m 644 "$REPO_ROOT/systemd/$f" "$PCG_SYSTEMD_TARGET/$f"
  done
  if [ ! -f "$PCG_ENV_TARGET" ] && [ -f "$PCG_ENV_EXAMPLE_SOURCE" ]; then
    install -m 600 "$PCG_ENV_EXAMPLE_SOURCE" "$PCG_ENV_TARGET"
  fi
}

install_canonical_files_from_source_dir() {
  local srcdir="$1"
  local f
  local bin_files=(
    "pcg-doctor.sh"
    "pcg-backup-config.sh"
    "pcg-boot-notify.sh"
    "pcg-send-telegram.sh"
    "pcg-send-webhook.sh"
    "pcg-shutdown-proxmox.sh"
    "pcg-agent-lib.sh"
    "pcg"
  )
  local unit_files=(
    "pcg-backup-config.service"
    "pcg-backup-config.timer"
    "pcg-boot-notify.service"
    "pcg-shutdown-proxmox.service"
  )

  mkdir -p "$PCG_BIN_TARGET" "$PCG_SYSTEMD_TARGET"

  for f in "${bin_files[@]}"; do
    install -m 755 "$srcdir/bin/$f" "$PCG_BIN_TARGET/$f"
  done
  for f in "${unit_files[@]}"; do
    install -m 644 "$srcdir/systemd/$f" "$PCG_SYSTEMD_TARGET/$f"
  done
  if [ ! -f "$PCG_ENV_TARGET" ] && [ -f "$srcdir/env/pcg-agent.env.example" ]; then
    install -m 600 "$srcdir/env/pcg-agent.env.example" "$PCG_ENV_TARGET"
  fi
}

enable_canonical_services() {
  pcg_systemctl daemon-reload
  pcg_systemctl enable pcg-backup-config.timer pcg-shutdown-proxmox.service pcg-boot-notify.service
  pcg_systemctl start pcg-backup-config.timer || true
}

doctor_add_result() {
  local key="$1"
  local status="$2"
  local message="$3"
  DOCTOR_KEYS+=("$key")
  DOCTOR_STATUS+=("$status")
  DOCTOR_MSG+=("$message")
  [ "$status" = "ok" ] || DOCTOR_FAILED=1
}

doctor_check_binary() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    doctor_add_result "bin:$name" "ok" "found"
  else
    doctor_add_result "bin:$name" "fail" "missing"
  fi
}

doctor_check_exec() {
  local path="$1"
  if [ -x "$path" ]; then
    doctor_add_result "exec:$path" "ok" "executable"
  else
    doctor_add_result "exec:$path" "fail" "not executable"
  fi
}

doctor_check_service_state() {
  local unit="$1"
  if is_test_mode; then
    doctor_add_result "enabled:$unit" "ok" "skipped (test mode)"
    return 0
  fi
  if systemctl is-enabled "$unit" >/dev/null 2>&1; then
    doctor_add_result "enabled:$unit" "ok" "enabled"
  else
    doctor_add_result "enabled:$unit" "fail" "not enabled"
  fi
}

doctor_check_active_state() {
  local unit="$1"
  if is_test_mode; then
    doctor_add_result "active:$unit" "ok" "skipped (test mode)"
    return 0
  fi
  if systemctl is-active "$unit" >/dev/null 2>&1; then
    doctor_add_result "active:$unit" "ok" "active"
  else
    doctor_add_result "active:$unit" "fail" "not active"
  fi
}

doctor_emit_plain() {
  local i
  for ((i=0; i<${#DOCTOR_KEYS[@]}; i++)); do
    echo "${DOCTOR_STATUS[$i]} ${DOCTOR_KEYS[$i]} ${DOCTOR_MSG[$i]}"
  done
  if [ "$DOCTOR_FAILED" -eq 0 ]; then
    echo "doctor: OK"
  else
    echo "doctor: FAIL"
  fi
}

doctor_emit_json() {
  local i first=1
  printf '{"ok":%s,"results":[' "$( [ "$DOCTOR_FAILED" -eq 0 ] && echo "true" || echo "false" )"
  for ((i=0; i<${#DOCTOR_KEYS[@]}; i++)); do
    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '{"key":"%s","status":"%s","message":"%s"}' \
      "$(pcg_json_escape "${DOCTOR_KEYS[$i]}")" \
      "$(pcg_json_escape "${DOCTOR_STATUS[$i]}")" \
      "$(pcg_json_escape "${DOCTOR_MSG[$i]}")"
  done
  printf ']}'
  echo
}

cmd_install() {
  local force_resume=0
  local clear_draft=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --resume) force_resume=1 ;;
      --clear-draft) clear_draft=1 ;;
      *) ui_err "Unknown option for install: $1"; exit 1 ;;
    esac
    shift
  done

  require_root

  if [ "$clear_draft" -eq 1 ]; then
    if [ -f "$PCG_ENV_DRAFT" ]; then
      clear_install_draft
      ui_ok "Cleared saved installer draft: $PCG_ENV_DRAFT"
    else
      ui_info "No saved installer draft found at $PCG_ENV_DRAFT"
    fi
    if [ "$force_resume" -eq 0 ]; then
      exit 0
    fi
  fi

  if [ "$force_resume" -eq 1 ] && [ ! -f "$PCG_ENV_DRAFT" ]; then
    ui_err "Resume requested but no saved draft was found at $PCG_ENV_DRAFT"
    ui_info "Run pcg install and choose Final action: save first."
    exit 1
  fi

  print_install_identity_block
  echo "${C_BOLD}Proxmox Agent installer${C_RESET}"
  ui_info "Starting guided installation..."
  if [ "$force_resume" -eq 1 ]; then
    ui_info "Resume mode enabled: saved settings will be loaded."
  fi

  preflight_checks || exit 1
  pcg_load_version
  if [ "${AGENT_VERSION:-unknown}" != "unknown" ]; then
    ui_warn "Detected existing installation version: v$AGENT_VERSION"
    local existing_action
    existing_action="$(prompt_existing_install_action)"
    case "$existing_action" in
      uninstall)
        perform_uninstall
        local uninstall_rc=$?
        [ "$uninstall_rc" -eq 2 ] && exit 0
        [ "$uninstall_rc" -eq 0 ] && exit 0
        exit 1
        ;;
      exit)
        ui_warn "Install cancelled by user."
        exit 0
        ;;
      reinstall)
        ;;
    esac
    if ! prompt_yes_no "Proceed with reinstall on this node?" "y"; then
      ui_warn "Install cancelled by user."
      exit 0
    fi
  else
    if ! prompt_yes_no "Proceed with installation changes on this node?" "n"; then
      ui_warn "Install cancelled by user."
      exit 0
    fi
  fi

  local ts backup_dir legacy_before migrated
  ts="$(date +%Y%m%d-%H%M%S)"
  backup_dir="$PA_BACKUP_DIR_BASE/install-$ts"
  mkdir -p "$PA_BACKUP_DIR_BASE"
  backup_current_install "$backup_dir"

  legacy_before=0
  detect_legacy_artifacts && legacy_before=1
  migrated=0

  if [ "$legacy_before" -eq 1 ]; then
    ui_warn "Detected legacy artifacts. Installer will migrate to pa-* naming."
  fi

  set +e
  install_canonical_files_from_repo
  local rc=$?
  if [ "$rc" -eq 0 ]; then
    migrate_env_file
    write_runtime_version "$(get_repo_version)"
    if [ "$rc" -eq 0 ]; then
      guided_env_setup "$force_resume"
      rc=$?
      if [ "$rc" -eq 2 ]; then
        restore_from_backup "$backup_dir"
        ui_warn "Install paused. Resume later with: pcg install --resume"
        exit 0
      elif [ "$rc" -ne 0 ]; then
        rc=1
      fi
    fi
    [ "$rc" -eq 0 ] && configure_repo_remote_if_needed
    [ "$rc" -eq 0 ] && validate_git_remote_access || rc=1
    [ "$rc" -eq 0 ] && disable_legacy_units
    [ "$rc" -eq 0 ] && enable_canonical_services || rc=1
    if [ "$rc" -eq 0 ] && [ "$legacy_before" -eq 1 ]; then
      remove_legacy_artifacts
      pcg_systemctl daemon-reload
      migrated=1
    fi
    [ "$rc" -eq 0 ] && "$PCG_BIN_TARGET/pcg" doctor >/dev/null 2>&1 || rc=1
  fi
  set -e

  if [ "$rc" -ne 0 ]; then
    restore_from_backup "$backup_dir"
    ui_err "Install failed and was rolled back from $backup_dir."
    exit 1
  fi

  pcg_load_version
  pcg_load_env
  pcg_send_webhook "install" "success" "Install completed" "Proxmox agent installed. migrated_legacy=$migrated" || true
  ui_ok "Install complete (agent v$(get_repo_version), migrated_legacy=$migrated)."
  ui_info "Next steps:"
  echo "  1) pcg doctor --json"
  echo "  2) pcg backup"
  if is_test_mode; then
    echo "  3) [test mode] systemctl checks skipped"
  else
    echo "  3) systemctl status pcg-backup-config.timer"
  fi
}

cmd_doctor() {
  local json=0
  if [ "${1:-}" = "--json" ]; then
    json=1
  fi

  DOCTOR_KEYS=()
  DOCTOR_STATUS=()
  DOCTOR_MSG=()
  DOCTOR_FAILED=0

  doctor_check_binary git
  doctor_check_binary curl
  doctor_check_binary ssh
  if is_test_mode; then
    doctor_add_result "bin:systemctl" "ok" "skipped (test mode)"
  else
    doctor_check_binary systemctl
  fi

  pcg_load_version
  if [ "${AGENT_VERSION:-unknown}" = "unknown" ]; then
    doctor_add_result "agent_version" "fail" "runtime version missing"
  else
    doctor_add_result "agent_version" "ok" "$AGENT_VERSION"
  fi

  if [ -f "$PCG_ENV_TARGET" ]; then
    doctor_add_result "env_file" "ok" "$PCG_ENV_TARGET"
  else
    doctor_add_result "env_file" "fail" "missing $PCG_ENV_TARGET"
  fi

  local legacy_count
  legacy_count="$(count_legacy_artifacts)"
  if [ "$legacy_count" -eq 0 ]; then
    doctor_add_result "migration_legacy_artifacts" "ok" "none"
  else
    doctor_add_result "migration_legacy_artifacts" "fail" "$legacy_count legacy artifacts still present"
  fi

  pcg_load_env
  if pcg_bool_true "${WEBHOOK_ENABLED:-false}"; then
    if [[ "${WEBHOOK_URL:-}" =~ ^https?:// ]]; then
      doctor_add_result "webhook_url" "ok" "configured"
    else
      doctor_add_result "webhook_url" "fail" "invalid or missing WEBHOOK_URL"
    fi
  else
    doctor_add_result "webhook_enabled" "ok" "disabled"
  fi

  if [ -n "${BOT_TOKEN:-}" ] && [ -n "${CHAT_ID:-}" ]; then
    doctor_add_result "telegram" "ok" "configured"
  else
    doctor_add_result "telegram" "ok" "not configured"
  fi

  doctor_check_exec "$PCG_BIN_TARGET/pcg-backup-config.sh"
  doctor_check_exec "$PCG_BIN_TARGET/pcg-send-telegram.sh"
  doctor_check_exec "$PCG_BIN_TARGET/pcg-send-webhook.sh"
  doctor_check_exec "$PCG_BIN_TARGET/pcg-shutdown-proxmox.sh"

  doctor_check_service_state pcg-backup-config.timer
  doctor_check_service_state pcg-shutdown-proxmox.service
  doctor_check_service_state pcg-boot-notify.service
  doctor_check_active_state pcg-backup-config.timer

  if is_ssh_remote_url "${GIT_REMOTE_URL:-}"; then
    if validate_github_ssh; then
      doctor_add_result "ssh_github" "ok" "authenticated"
    else
      doctor_add_result "ssh_github" "fail" "authentication failed"
    fi
  elif is_https_remote_url "${GIT_REMOTE_URL:-}"; then
    doctor_add_result "ssh_github" "ok" "skipped (HTTPS remote)"
  else
    doctor_add_result "ssh_github" "ok" "skipped (no SSH remote configured)"
  fi

  if validate_git_remote_access 1; then
    doctor_add_result "git_remote" "ok" "reachable"
  else
    doctor_add_result "git_remote" "fail" "unreachable"
  fi

  if [ "$json" -eq 1 ]; then
    doctor_emit_json
  else
    doctor_emit_plain
  fi

  pcg_send_webhook "doctor" "$( [ "$DOCTOR_FAILED" -eq 0 ] && echo success || echo failed )" \
    "Doctor completed" \
    "Doctor run finished with status $( [ "$DOCTOR_FAILED" -eq 0 ] && echo ok || echo fail )." || true

  [ "$DOCTOR_FAILED" -eq 0 ]
}

cmd_backup() {
  require_root
  "$PCG_BIN_TARGET/pcg-backup-config.sh"
}

cmd_notify() {
  require_root
  local msg="${1:-Proxmox agent notification test}"
  if "$PCG_BIN_TARGET/pcg-send-telegram.sh" "$msg"; then
    ui_ok "Telegram notification sent."
  else
    ui_err "Telegram notification failed."
    exit 1
  fi
}

resolve_latest_tag() {
  local source="$1"
  git ls-remote --tags --refs "$source" \
    | awk '{print $2}' \
    | sed 's#refs/tags/##' \
    | sort -V \
    | tail -n 1
}

extract_edge_source() {
  local source="$1"
  local tmpdir="$2"
  local archive="$tmpdir/edge-archive"
  mkdir -p "$tmpdir"
  curl -fsSL "$source" -o "$archive"

  if [[ "$source" =~ \.zip($|\?) ]]; then
    unzip -q "$archive" -d "$tmpdir/extracted"
  else
    mkdir -p "$tmpdir/extracted"
    tar -xf "$archive" -C "$tmpdir/extracted"
  fi

  find "$tmpdir/extracted" -type f -name VERSION -printf '%h\n' | head -n 1
}

cmd_upgrade() {
  require_root

  pa_load_version
  pa_load_env

  local channel target source
  channel="${AGENT_UPDATE_CHANNEL:-stable}"
  target=""
  source="${AGENT_UPDATE_SOURCE:-}"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --channel) channel="${2:-}"; shift 2 ;;
      --target) target="${2:-}"; shift 2 ;;
      *) ui_err "Unknown option: $1"; exit 1 ;;
    esac
  done

  if [ -z "$source" ]; then
    ui_err "AGENT_UPDATE_SOURCE is required for upgrade."
    exit 1
  fi

  local tmpdir srcdir target_version current_version ts backup_dir rc legacy_before migrated
  tmpdir="$(mktemp -d)"
  ts="$(date +%Y%m%d-%H%M%S)"
  backup_dir="$PA_BACKUP_DIR_BASE/upgrade-$ts"
  mkdir -p "$PA_BACKUP_DIR_BASE"
  backup_current_install "$backup_dir"

  current_version="${AGENT_VERSION:-unknown}"
  legacy_before=0
  migrated=0
  detect_legacy_artifacts && legacy_before=1

  mkdir -p "$(dirname "$PCG_UPGRADE_LOG")"
  touch "$PCG_UPGRADE_LOG"

  if [ "$channel" = "stable" ]; then
    [ -n "$target" ] || target="$(resolve_latest_tag "$source")"
    [ -n "$target" ] || { ui_err "Cannot resolve stable target tag."; exit 1; }
    git clone --depth 1 --branch "$target" "$source" "$tmpdir/src" >/dev/null 2>&1
    srcdir="$tmpdir/src"
  elif [ "$channel" = "edge" ]; then
    srcdir="$(extract_edge_source "$source" "$tmpdir")"
    [ -n "$srcdir" ] || { ui_err "Cannot extract edge source."; exit 1; }
  else
    ui_err "Invalid channel: $channel"
    exit 1
  fi

  [ -f "$srcdir/VERSION" ] || { ui_err "Upgrade source missing VERSION file."; exit 1; }
  target_version="$(tr -d '[:space:]' < "$srcdir/VERSION")"

  if [ "$current_version" = "$target_version" ]; then
    ui_info "Already up to date (v$current_version)."
    exit 0
  fi

  echo "$(date -Is) channel=$channel source=$source current=$current_version target=$target_version backup=$backup_dir legacy_before=$legacy_before" >> "$PCG_UPGRADE_LOG"

  set +e
  install_canonical_files_from_source_dir "$srcdir"
  rc=$?
  if [ "$rc" -eq 0 ]; then
    migrate_env_file
    write_runtime_version "$target_version"
    disable_legacy_units
    enable_canonical_services || rc=1
    if [ "$rc" -eq 0 ] && [ "$legacy_before" -eq 1 ]; then
      remove_legacy_artifacts
      pcg_systemctl daemon-reload
      migrated=1
    fi
    [ "$rc" -eq 0 ] && "$PCG_BIN_TARGET/pcg" doctor >/dev/null 2>&1 || rc=1
  fi
  set -e

  if [ "$rc" -ne 0 ]; then
    restore_from_backup "$backup_dir"
    ui_err "Post-upgrade validation failed; rolled back from $backup_dir."
    exit 1
  fi

  pcg_load_version
  pcg_load_env
  pcg_send_webhook "install" "success" "Upgrade completed" \
    "Upgraded from v$current_version to v$target_version via $channel; migrated_legacy=$migrated." || true

  echo "$(date -Is) status=success migrated_legacy=$migrated" >> "$PCG_UPGRADE_LOG"
  ui_ok "Upgrade complete: v$current_version -> v$target_version ($channel, migrated_legacy=$migrated)."
}

usage() {
  cat <<EOF
Usage: pcg <command> [options]

Commands:
  install [--resume|--clear-draft]
                          Install scripts, units, version file, and validate setup
                          --resume: load saved draft settings and continue guided install
                          --clear-draft: remove saved draft settings file and exit
  doctor [--json]         Run health checks
  preinstall-report [--json]
                          Read-only simulation report of current state vs planned install changes
  backup                  Run backup script manually
  notify [message]        Send Telegram test message
  uninstall               Remove managed agent scripts, units, version file, and env files
  upgrade [--channel stable|edge] [--target <tag>]
EOF
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    install) cmd_install "$@" ;;
    doctor) cmd_doctor "$@" ;;
    preinstall-report|pcg-doctor) cmd_preinstall_report "$@" ;;
    backup) cmd_backup "$@" ;;
    notify) cmd_notify "$@" ;;
    uninstall) perform_uninstall "$@" ;;
    upgrade) cmd_upgrade "$@" ;;
    ""|-h|--help|help) usage ;;
    *)
      ui_err "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
